<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up app preferences (includes SharedPreferences used by settings). -->
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Keep prefs during device-to-device transfer as well. -->
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
